{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"dialog:default",
		"dialog:allow-open",
		"core:webview:allow-internal-toggle-devtools",
		{
			"identifier": "opener:allow-open-url",
			"allow": [
				{
					"url": "https://*",
					"app": true
				}
			]
		}
	]
}
